<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/txtBookingTourTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tour Name"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Adult row (grouped horizontally) -->
    <LinearLayout
        android:id="@+id/rowAdult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtBookingTourTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtPriceAdultLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Adult: $100"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnMinusAdult"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="-"
            android:contentDescription="Decrease adult count" />

        <TextView
            android:id="@+id/txtCountAdult"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="1"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnPlusAdult"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:contentDescription="Increase adult count" />
    </LinearLayout>

    <!-- Child row (grouped horizontally) -->
    <LinearLayout
        android:id="@+id/rowChild"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/rowAdult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtPriceChildLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Child: $50"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnMinusChild"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="-"
            android:contentDescription="Decrease child count" />

        <TextView
            android:id="@+id/txtCountChild"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="0"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnPlusChild"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:contentDescription="Increase child count" />
    </LinearLayout>

    <!-- Total price -->
    <TextView
        android:id="@+id/txtBookingTotalPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Total: $100"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/rowChild"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Pay button (ZaloPay) anchored to bottom -->
    <Button
        android:id="@+id/btnPayZaloPay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pay with ZaloPay"
        android:layout_margin="16dp"
        android:contentDescription="Pay with ZaloPay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>